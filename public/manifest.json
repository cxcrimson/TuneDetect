{
  "manifest_version": 3,
  "name": "TuneDetect Pro",
  "version": "1.0.0",
  "description": "Real-time key and mode detector for YouTube music.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "tabCapture",
    "activeTab"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
