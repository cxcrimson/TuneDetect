{
  "manifest_version": 3,
  "name": "TuneDetect Pro",
  "version": "1.0.0",
  "description": "Real-time key and mode detector for YouTube music.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "tabCapture",
    "activeTab",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
